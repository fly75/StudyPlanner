<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiApp16.ViewModels"
             x:Class="MauiApp16.Views.AuthorizationPage"
             BackgroundColor="{DynamicResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">

            <!-- Logo Section -->
            <VerticalStackLayout Spacing="10" Margin="0,0,0,30">
                <Label Text="📚" 
                       FontSize="64" 
                       HorizontalOptions="Center"/>

                <Label Text="Study Planner" 
                       FontSize="36" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource Primary}" />

                <Label Text="Розумний менеджер навчання" 
                       FontSize="16" 
                       HorizontalOptions="Center"
                       TextColor="{DynamicResource TextSecondary}"/>
            </VerticalStackLayout>

            <!-- Login Form -->
            <Frame CornerRadius="20"
                   Padding="20"
                   HasShadow="True"
                   BackgroundColor="{DynamicResource Surface}"
                   Margin="0,10">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Вхід до системи" 
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource TextSecondary}"
                           HorizontalOptions="Center"/>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="8" Margin="20,0">
                        <Label Text="📧 Email" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"/>
                        <Frame CornerRadius="12" 
                               Padding="0" 
                               HasShadow="False"
                               BackgroundColor="{DynamicResource Background}">
                            <Entry Placeholder="example@email.com" 
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   IsSpellCheckEnabled="False"
                                   IsTextPredictionEnabled="False"
                                   TextColor="{DynamicResource TextPrimary}"
                                   PlaceholderColor="{DynamicResource Gray500}"
                                   BackgroundColor="Transparent"
                                   Margin="15,0"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8" Margin="20,0">
                        <Label Text="🔒 Пароль" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextPrimary}"/>
                        <Frame CornerRadius="12" 
                               Padding="0" 
                               HasShadow="False"
                               BackgroundColor="{DynamicResource Background}">
                            <Entry Placeholder="Введіть пароль" 
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   TextColor="{DynamicResource TextPrimary}"
                                   PlaceholderColor="{DynamicResource Gray500}"
                                   BackgroundColor="Transparent"
                                   Margin="15,0"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Frame CornerRadius="12" 
                           Padding="15" 
                           HasShadow="False"
                           Margin="20,0"
                           BackgroundColor="#FFEBEE"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotNullOrEmptyConverter}}">
                        <Label Text="{Binding ErrorMessage}" 
                               TextColor="{StaticResource Error}"
                               FontSize="14"
                               HorizontalTextAlignment="Center"/>
                    </Frame>

                    <!-- Login Button -->
                    <Button Text="🚀 Увійти" 
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="{DynamicResource Primary}"
                            TextColor="{DynamicResource SurfaceLight}"
                            FontSize="18"
                            HeightRequest="55"/>

                    <!-- Register Button -->
                    <Button Text="✨ Зареєструватися" 
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="Transparent"
                            TextColor="{DynamicResource Primary}"
                            BorderColor="{DynamicResource Primary}"
                            BorderWidth="2"
                            FontSize="18"
                            HeightRequest="55"/>

                    <!-- Activity Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}" 
                                     IsVisible="{Binding IsBusy}"
                                     Color="{DynamicResource Primary}"
                                     HeightRequest="40"
                                     Margin="0,10"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>